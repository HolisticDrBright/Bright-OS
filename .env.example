# ============================================================
# BRIGHT OS environment — copy to .env and fill in.
# NOTHING in here may ever be committed. .env is git-ignored.
# ============================================================

# ---------- Supabase (NEW project — create at supabase.com) ----------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server/workers only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (Settings → Database). Used by nightly pg_dump backups.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---------- Single-user auth ----------
# The only email allowed to sign in (Supabase email OTP).
ALLOWED_EMAIL=you@example.com

# ---------- App ----------
APP_BASE_URL=http://localhost:3100
TZ=America/Los_Angeles

# ---------- Claude API (the /api/command reactor brain) ----------
ANTHROPIC_API_KEY=
COMMAND_MODEL=claude-sonnet-5
CLASSIFY_MODEL=claude-haiku-4-5

# ---------- Guardrails ----------
# Daily agent spend cap in USD. Workers pause + alert when exceeded.
DAILY_COST_CAP_USD=60
# Shared secret for HMAC-signing /api/heartbeat ingest calls (x-brightos-signature).
HEARTBEAT_HMAC_SECRET=
# Bearer token agents (OpenClaw, Hermes) use for /api/agent/* endpoints.
AGENT_API_TOKEN=

# ---------- Files ----------
# Heartbeat checklist read by the 30-min worker (< 50 lines).
HEARTBEAT_MD_PATH=./HEARTBEAT.md
# Curated long-term memory doc. Point into the Obsidian vault to keep one source of truth.
MEMORY_MD_PATH=./MEMORY.md

# ---------- Telegram (approval surface) ----------
TELEGRAM_BOT_TOKEN=
# The ONE chat id the bot will talk to. Everything else is ignored.
TELEGRAM_CHAT_ID=
# Random string; Telegram echoes it in X-Telegram-Bot-Api-Secret-Token on webhook calls.
TELEGRAM_WEBHOOK_SECRET=
# Optional: OpenAI key for Whisper voice-note transcription (voice → /api/command),
# the HUD "Jarvis" text-to-speech voice (/api/tts), AND memory embeddings for
# semantic recall. Without it: browser TTS fallback + keyword-only memory search.
OPENAI_API_KEY=
# Embedding model for long-term memory recall (1536 dims — matches the DB column)
EMBEDDING_MODEL=text-embedding-3-small
# Where the brain's editable files live (PERSONALITY.md / KNOWLEDGE.md / SELF.md).
# When OBSIDIAN_VAULT_PATH is set, the copies in {vault}/BrightOS/ take priority
# and are seeded from this folder on first run.
BRAIN_DIR=./brain
# Optional TTS tuning (defaults shown): the deep AI-butler "Jarvis" voice.
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=onyx
# TTS_INSTRUCTIONS="Deep, authoritative AI butler in the spirit of JARVIS. Composed, deliberate, and articulate with quiet gravitas. Unhurried cadence, subtly warm, dry understatement. Never robotic, never sing-song."

# ---------- GoHighLevel (waitlist counts) ----------
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional custom base (defaults to https://services.leadconnectorhq.com)
GHL_BASE_URL=
# Optional contact-search term to count only the waitlist segment
GHL_WAITLIST_TAG=

# ---------- Heartbeat tuning (defaults shown) ----------
DECISION_AGING_HOURS=24
GHL_DELTA_ALERT=50
GSC_CLICK_PCT=20
BOARD_IDLE_HOURS=72

# ---------- Google Search Console (clicks/position deltas) ----------
# Service-account JSON credentials (escape newlines in the private key as \n).
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
# Comma-separated: brandName|siteUrl|query1;query2
# e.g. QCL|https://quantumcompounding.com|bpc-157 vs tb-500;peptide safety
GSC_TRACKED=

# ---------- OpenClaw (existing instance — keeps WordPress/exec lanes) ----------
# Deep-linked from the OPENCLAW agent card; its skill posts back to /api/*.
OPENCLAW_URL=

# ---------- Hermes agent (memory + research lane, self-hosted) ----------
HERMES_URL=http://localhost:8000
HERMES_API_KEY=
HERMES_MODEL=Hermes-4.3
# Deep link shown on the HERMES agent card (its own dashboard — we don't rebuild it).
NEXT_PUBLIC_HERMES_DASHBOARD_URL=http://localhost:8000

# ---------- Obsidian bridge (OneDrive-synced vault) ----------
OBSIDIAN_VAULT_PATH=/data/vault
OBSIDIAN_DAILY_NOTES_DIR=Daily Notes
OBSIDIAN_TASKS_DIR=Tasks
OBSIDIAN_BOARD_NOTE=Active Command Board.md
OBSIDIAN_CLOSEOUT_DIR=Closeouts

# ---------- Mission Control V2 import (one-shot) ----------
MCV2_SUPABASE_URL=
MCV2_SUPABASE_SERVICE_KEY=

# ---------- Backups ----------
# Local staging dir for pg_dump output before upload.
BACKUP_DIR=./backups
# Optional rclone remote for the weekly OFF-SITE copy, e.g. b2:brightos-backups
OFFSITE_RCLONE_REMOTE=
